# Backend env — Supabase Edge Function secrets.
#
# IMPORTANT: SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are
# injected into every edge function by the platform automatically — do NOT set
# them here. Set the secrets below with:  supabase secrets set --env-file .env
#
# Required only for LIVE payments (omit to use the built-in mock activation):
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Stripe webhook signing secret (for the stripe-webhook function that activates
# the subscription after checkout). From the Stripe dashboard webhook endpoint.
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret

# Optional integrations — each function falls back to mock data when unset:
# PAYME_MERCHANT_ID=     # PayMe (Uzbekistan) checkout in process-subscription
# YOUTUBE_API_KEY=       # real YouTube stats in fetch-social-stats

# ── discover-influencers (populate the league with real Uzbek bloggers) ───────
# Set the real values via `supabase secrets set ...`, NOT by committing them here.
# YOUTUBE_DATA_API_KEY=  # YouTube Data API v3 key — required for discovery
# APIFY_API_KEY=         # optional — Instagram/TikTok enrichment via Apify
# ENSEMBLEDATA_TOKEN=    # optional — EnsembleData social API
# SOCIALKIT_API_KEY=     # optional — SocialKit social API
# DISCOVER_SECRET=       # optional — require x-admin-secret header to invoke
    
# ── UZ payments (T-05 / T-06) ─────────────────────────────────────────────────
# Payme Merchant API (payme-webhook). Sandbox: set only the TEST key and point
# the sandbox cabinet at .../functions/v1/payme-webhook
# PAYME_MERCHANT_KEY=        # production key from the Payme cabinet
# PAYME_MERCHANT_TEST_KEY=   # sandbox key (test.paycom.uz)
# Click SHOPAPI (click-webhook)
# CLICK_SERVICE_ID=
# CLICK_MERCHANT_ID=
# CLICK_SECRET_KEY=
# USD→UZS rate used to price plans/deals in tiyin (admin-updated constant;
# keep in sync with frontend/src/lib/plans.ts)
# UZS_PER_USD=12800
