# ── Discovery worker config ──────────────────────────────────────────────────
# Copy to .env and fill in. The SERVICE ROLE key bypasses RLS — keep it secret.

# Supabase
SUPABASE_URL=https://ceqpcuhguxjdbzuuwamr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Platform API keys
YOUTUBE_DATA_API_KEY=
APIFY_API_KEY=                 # omit to skip Instagram/TikTok (paid)

# Discovery options
REGIONS=UZ                     # e.g. UZ,KZ,RU
YT_MAX=150
# Optional — override the baked UZ starter lists:
# TG_CHANNELS=kunuz,gazetauz,daryo_uz
# IG_USERS=kun.uz,gazeta.uz
# TT_USERS=kun.uz

# Healthcheck / alerting
# Each run writes a row to public.discovery_runs (heartbeat). Set this to get a
# Slack ping whenever a job fails. Leave blank to disable Slack alerts.
SLACK_WEBHOOK_URL=

# Schedule (busybox cron expression, UTC). Default: daily at 03:00.
CRON_SCHEDULE=0 3 * * *
# Run once immediately on container start (1/0).
RUN_ON_START=1
